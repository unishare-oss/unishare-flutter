rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /universities/{universityId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Achievements badge catalog — public read, admin-managed writes.
    match /badges/{badgeId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Public-safe mirror of users/{uid} — name, photoUrl, bio, and the
    // gamification fields safe to expose cross-user (level, selectedTitle,
    // displayedBadges). Maintained by the onUserChangedPublicSync Cloud
    // Function; never client-written.
    match /users_public/{uid} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Tunable level threshold table and other app-wide config — public read,
    // admin-managed writes.
    match /app_config/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /departments/{departmentId} {
      allow read: if true;
      allow write: if isAdmin();

      match /courses/{courseId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /users/{userId} {
      // Owner-only reads keep `email` and other private fields private.
      // Admins may read any user (and list the collection) to power the admin
      // console — isAdmin() does not depend on userId, so it also authorizes
      // list queries. Cross-user gamification display still goes through the
      // public mirror `users_public/{uid}`.
      allow read: if request.auth != null
                  && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == userId;

      // Owner-only updates, with server-managed gamification/stats fields
      // off-limits. Validators only fire when the cosmetic fields are part
      // of the change so unrelated profile edits aren't blocked by stale
      // `gamification` data.
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && !writesProtectedAchievementsFields()
                    && !writesRole()
                    && (!touchesDisplayedBadges() || validDisplayedBadges())
                    && (!touchesSelectedTitle() || validSelectedTitle());
      allow delete: if false;

      // Compare the protected values directly. `diff(...).affectedKeys()`
      // only reports top-level keys, so dotted-path checks would silently
      // miss nested writes under `gamification`. Comparing the actual
      // values is the only reliable way to detect the change.
      function writesRole() {
        return request.resource.data.get('role', null)
            != resource.data.get('role', null);
      }

      function writesProtectedAchievementsFields() {
        let beforeG = resource.data.get('gamification', {});
        let afterG = request.resource.data.get('gamification', {});
        return request.resource.data.get('stats', {}) != resource.data.get('stats', {})
            || beforeG.get('totalPoints', 0) != afterG.get('totalPoints', 0)
            || beforeG.get('level', 0) != afterG.get('level', 0)
            || beforeG.get('earnedBadgesCache', []) != afterG.get('earnedBadgesCache', []);
      }

      function earnedCache() {
        return resource.data.get(['gamification', 'earnedBadgesCache'], []);
      }

      function touchesDisplayedBadges() {
        return request.resource.data.get(['gamification', 'displayedBadges'], [])
            != resource.data.get(['gamification', 'displayedBadges'], []);
      }

      function touchesSelectedTitle() {
        return request.resource.data.get(['gamification', 'selectedTitle'], null)
            != resource.data.get(['gamification', 'selectedTitle'], null);
      }

      function validDisplayedBadges() {
        let proposed = request.resource.data.get(['gamification', 'displayedBadges'], []);
        return proposed is list
               && proposed.size() <= 3
               && proposed.toSet().size() == proposed.size()
               && proposed.toSet().difference(earnedCache().toSet()).size() == 0;
      }

      function validSelectedTitle() {
        let t = request.resource.data.get(['gamification', 'selectedTitle'], null);
        return t == null || t in earnedCache();
      }

      match /preferences {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /savedPosts/{postId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Earned badges — server-only writes (achievements evaluator).
      // Reads are open to any authenticated user so badges are visible on
      // other users' profiles and on the leaderboard.
      match /earnedBadges/{badgeId} {
        allow read: if request.auth != null;
        allow write: if false;
      }

      // Unique-savers presence set — server-only.
      match /uniqueSavers/{saverUid} {
        allow read, write: if false;
      }

      // Notification inbox — server (Admin SDK) writes; client reads and marks read only.
      match /notifications/{notifId} {
        // Owner can read their own notifications.
        allow read: if request.auth != null && request.auth.uid == userId;

        // No client creates — all documents are written by Cloud Functions via Admin SDK.
        allow create: if false;

        // Owner may update only the isRead field.
        allow update: if request.auth != null
                      && request.auth.uid == userId
                      && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['isRead'])
                      && request.resource.data.isRead is bool;

        // No client deletes — retention is managed by the scheduled Cloud Function.
        allow delete: if false;
      }

      // FCM tokens — owner manages their own device tokens only.
      match /fcmTokens/{tokenHash} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Collection-group rule for collectionGroup('comments') queries.
    // Nested per-post rules don't apply to CG queries, so we need this here.
    //
    // Only allow CG reads to authenticated callers requesting documents
    // they authored — this powers the profile-stats "your comment count"
    // query and nothing else. Direct (non-CG) reads of a specific post's
    // comments still go through the open `posts/{postId}/comments` rule.
    match /{path=**}/comments/{commentId} {
      allow read: if request.auth != null
                  && resource.data.authorId == request.auth.uid;
    }

    match /posts/{postId} {
      // Approved posts are public; pending/rejected posts are visible only to
      // the author and moderators.
      allow read: if resource.data.status == 'approved'
                  || (request.auth != null && request.auth.uid == resource.data.authorId)
                  || isModerator();
      allow create: if request.auth != null
                    && request.resource.data.authorId == request.auth.uid
                    && request.resource.data.title is string
                    && request.resource.data.title.size() > 0
                    && request.resource.data.likesCount == 0
                    && request.resource.data.status == 'pending'
                    && !('aiVerdict' in request.resource.data)
                    && !('moderatedBy' in request.resource.data)
                    && !('moderatedAt' in request.resource.data)
                    && !('rejectionReason' in request.resource.data);
      allow update: if request.auth != null
                    && (
                      // Any authenticated user may increment/decrement likesCount
                      // or reactionCounts (reaction toggles update the map field).
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['likesCount', 'reactionCounts'])
                      || (
                        request.auth.uid == resource.data.authorId
                        && request.resource.data.diff(resource.data).affectedKeys()
                             .hasOnly([
                               'title', 'description', 'tags', 'externalUrl',
                               'moduleNumber', 'updatedAt',
                               'summary', 'summaryStatus', 'summarizedAt'
                             ])
                        && request.resource.data.title is string
                        && request.resource.data.title.size() > 0
                      )
                      || (
                        request.auth.uid == resource.data.authorId
                        && request.resource.data.diff(resource.data).affectedKeys()
                             .hasOnly(['summaryStatus', 'summary', 'summarizedAt'])
                      )
                      || (
                        isModerator()
                        && request.resource.data.diff(resource.data).affectedKeys()
                             .hasOnly(['status', 'moderatedBy', 'moderatedAt', 'rejectionReason'])
                        && request.resource.data.status in ['approved', 'rejected']
                      )
                    );
      // Author may delete their own post; an admin may take down any post.
      allow delete: if request.auth != null
                    && (request.auth.uid == resource.data.authorId || isAdmin());

      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null
                      && request.resource.data.authorId == request.auth.uid
                      && request.resource.data.body is string
                      && request.resource.data.body.size() > 0;
        // Author may delete their own comment; an admin may remove any comment.
        allow delete: if request.auth != null
                      && (resource.data.authorId == request.auth.uid || isAdmin());
        allow update: if false;
      }

      match /likes/{userId} {
        allow read: if true;
        allow create, delete: if request.auth != null
                               && request.auth.uid == userId;
        allow update: if false;
      }

      // Per-user reaction document keyed by uid. Each field is a reaction type
      // (e.g. "thumbsUp": true). The transaction reads and writes only the
      // requesting user's own document.
      match /reactions/{userId} {
        allow read: if true;
        allow create, update, delete: if request.auth != null
                                      && request.auth.uid == userId;
      }
    }

    // Role hierarchy. `admin` is a superset of `moderator`: anything a
    // moderator may do, an admin may do too. The role lives on
    // users/{uid}.role and is never client-writable (see writesRole()); it is
    // changed only via the admin-gated setUserRole callable.
    function userRole() {
      return request.auth != null
          ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'student')
          : '';
    }
    function isAdmin() {
      return userRole() == 'admin';
    }
    function isModerator() {
      return userRole() == 'moderator' || isAdmin();
    }

    match /requests/{requestId} {
      // Anyone authenticated can read requests
      allow read: if request.auth != null;

      // Only authenticated users can create; requesterId must match caller
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['title', 'requesterId', 'status', 'upvoteCount', 'createdAt'])
        && request.resource.data.requesterId == request.auth.uid
        && request.resource.data.status == 'open'
        && request.resource.data.upvoteCount == 0
        && request.resource.data.title.size() <= 120
        && (!('description' in request.resource.data)
            || request.resource.data.description == null
            || request.resource.data.description.size() <= 500);

      // Any authenticated user may upvote (upvoteCount only);
      // the requester may update status/fulfilledBy fields.
      allow update: if request.auth != null
        && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvoteCount'])
          || (request.auth.uid == resource.data.requesterId
              && request.resource.data.diff(resource.data).affectedKeys()
                   .hasOnly(['status', 'fulfilledByPostId', 'fulfilledByPostTitle', 'updatedAt']))
        );

      allow delete: if request.auth != null
        && resource.data.requesterId == request.auth.uid;

      match /suggestions/{suggestionId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.suggestedByUserId == request.auth.uid;
        allow update: if false;
        allow delete: if request.auth != null
          && get(/databases/$(database)/documents/requests/$(requestId)).data.requesterId == request.auth.uid;
      }

      match /upvotes/{userId} {
        allow read: if request.auth != null;
        allow create, delete: if request.auth != null
          && request.auth.uid == userId;
        allow update: if false;
      }
    }
  }
}
