rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /universities/{universityId} {
      allow read: if true;
      allow write: if false;
    }

    // Achievements badge catalog — public read, seed-only writes.
    match /badges/{badgeId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Tunable level threshold table and other app-wide config — public read,
    // seed-only writes.
    match /app_config/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /departments/{departmentId} {
      allow read: if true;
      allow write: if false;

      match /courses/{courseId} {
        allow read: if true;
        allow write: if false;
      }
    }

    match /users/{userId} {
      // Profiles are publicly readable for any authenticated user (so other
      // users can view names, badges, etc. on posts/comments).
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;

      // Owner-only updates, with server-managed gamification/stats fields
      // explicitly off-limits. The evaluator (Cloud Function) writes
      // gamification.totalPoints, gamification.level, gamification.earnedBadgesCache,
      // and the entire `stats` map.
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && !writesProtectedAchievementsFields()
                    && validDisplayedBadges()
                    && validSelectedTitle();
      allow delete: if false;

      function writesProtectedAchievementsFields() {
        let changed = request.resource.data.diff(resource.data).affectedKeys();
        return changed.hasAny([
          'stats',
          'gamification.totalPoints',
          'gamification.level',
          'gamification.earnedBadgesCache',
        ]);
      }

      function earnedCache() {
        return resource.data.get(['gamification', 'earnedBadgesCache'], []);
      }

      function validDisplayedBadges() {
        let proposed = request.resource.data.get(['gamification', 'displayedBadges'], []);
        return proposed is list
               && proposed.size() <= 3
               && proposed.toSet().size() == proposed.size()
               && proposed.toSet().difference(earnedCache().toSet()).size() == 0;
      }

      function validSelectedTitle() {
        let t = request.resource.data.get(['gamification', 'selectedTitle'], null);
        return t == null || t in earnedCache();
      }

      match /preferences {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /savedPosts/{postId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Earned badges — server-only writes (achievements evaluator).
      // Reads are open to any authenticated user so badges are visible on
      // other users' profiles and on the leaderboard.
      match /earnedBadges/{badgeId} {
        allow read: if request.auth != null;
        allow write: if false;
      }

      // Unique-savers presence set — server-only.
      match /uniqueSavers/{saverUid} {
        allow read, write: if false;
      }

      // Notification inbox — server (Admin SDK) writes; client reads and marks read only.
      match /notifications/{notifId} {
        // Owner can read their own notifications.
        allow read: if request.auth != null && request.auth.uid == userId;

        // No client creates — all documents are written by Cloud Functions via Admin SDK.
        allow create: if false;

        // Owner may update only the isRead field.
        allow update: if request.auth != null
                      && request.auth.uid == userId
                      && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['isRead'])
                      && request.resource.data.isRead is bool;

        // No client deletes — retention is managed by the scheduled Cloud Function.
        allow delete: if false;
      }

      // FCM tokens — owner manages their own device tokens only.
      match /fcmTokens/{tokenHash} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Collection-group rule for collectionGroup('comments') queries.
    // Nested per-post rules don't apply to CG queries, so we need this here.
    //
    // Only allow CG reads to authenticated callers requesting documents
    // they authored — this powers the profile-stats "your comment count"
    // query and nothing else. Direct (non-CG) reads of a specific post's
    // comments still go through the open `posts/{postId}/comments` rule.
    match /{path=**}/comments/{commentId} {
      allow read: if request.auth != null
                  && resource.data.authorId == request.auth.uid;
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.authorId == request.auth.uid
                    && request.resource.data.title is string
                    && request.resource.data.title.size() > 0
                    && request.resource.data.likesCount == 0;
      allow update: if request.auth != null
                    && (
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['likesCount'])
                      || (
                        request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['summaryStatus', 'summary', 'summarizedAt'])
                        && resource.data.authorId == request.auth.uid
                      )
                    );
      allow delete: if false;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null
                      && request.resource.data.authorId == request.auth.uid
                      && request.resource.data.body is string
                      && request.resource.data.body.size() > 0;
        allow delete: if request.auth != null
                      && resource.data.authorId == request.auth.uid;
        allow update: if false;
      }

      match /likes/{userId} {
        allow read: if true;
        allow create, delete: if request.auth != null
                               && request.auth.uid == userId;
        allow update: if false;
      }
    }

    match /requests/{requestId} {
      // Anyone authenticated can read requests
      allow read: if request.auth != null;

      // Only authenticated users can create; requesterId must match caller
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['title', 'requesterId', 'status', 'upvoteCount', 'createdAt'])
        && request.resource.data.requesterId == request.auth.uid
        && request.resource.data.status == 'open'
        && request.resource.data.upvoteCount == 0
        && request.resource.data.title.size() <= 120
        && (!('description' in request.resource.data)
            || request.resource.data.description == null
            || request.resource.data.description.size() <= 500);

      // Any authenticated user may upvote (upvoteCount only);
      // the requester may update status/fulfilledBy fields.
      allow update: if request.auth != null
        && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvoteCount'])
          || (request.auth.uid == resource.data.requesterId
              && request.resource.data.diff(resource.data).affectedKeys()
                   .hasOnly(['status', 'fulfilledByPostId', 'fulfilledByPostTitle', 'updatedAt']))
        );

      allow delete: if request.auth != null
        && resource.data.requesterId == request.auth.uid;

      match /suggestions/{suggestionId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.suggestedByUserId == request.auth.uid;
        allow update: if false;
        allow delete: if request.auth != null
          && get(/databases/$(database)/documents/requests/$(requestId)).data.requesterId == request.auth.uid;
      }

      match /upvotes/{userId} {
        allow read: if request.auth != null;
        allow create, delete: if request.auth != null
          && request.auth.uid == userId;
        allow update: if false;
      }
    }
  }
}
